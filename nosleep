#!/bin/bash
# nosleep, toggle macOS lid-close sleep prevention (pmset disablesleep)
#
#   nosleep           toggle on/off
#   nosleep on        disable sleep indefinitely
#   nosleep off       re-enable sleep
#   nosleep 30m       disable sleep for 30 minutes (also Ns / Nh)
#   nosleep status    show current state
#   nosleep clean     quit all Dock apps except the whitelist, then no-sleep
#   nosleep whitelist manage which apps survive a clean
#   nosleep help      show usage
#   nosleep version   show version
#
# Timed mode starts a root background timer immediately (while sudo
# credentials are fresh), so no password is needed when it fires.
set -euo pipefail

VERSION="1.3.0"
PIDFILE="/tmp/nosleep-timer.pid"   # format: "<pid> <deadline-epoch>"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nosleep"
WHITELIST_FILE="$CONFIG_DIR/whitelist"

BATTERY_MIN=15          # auto-restore sleep if battery drops below this percent
POLL_INTERVAL=30        # seconds between battery/deadline checks in the watcher
WARN_ABOVE=3600         # confirm before keeping awake longer than this (1h)
LID_POLL=2              # seconds between lid checks while the lid is open (chime)
DEFAULT_SOUND="Submarine"        # chime on lid-close; change via 'nosleep sound'
SOUND_FILE="$CONFIG_DIR/sound"   # stores the chime name, or "off"

# Absolute path to this script, so the background watcher can re-exec it as root.
case "$0" in
  */*) SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")" ;;
  *)   SELF="$(command -v "$0")" ;;
esac

ESC=$'\033'
RED="${ESC}[91m"; YEL="${ESC}[93m"; GRN="${ESC}[92m"; BLD="${ESC}[1m"; DIM="${ESC}[2m"; RST="${ESC}[0m"

usage() {
  cat <<'EOF'
usage: nosleep [on|off|status|clean|whitelist|sound|insist|<N>s|<N>m|<N>h|help|version]

  nosleep             toggle on/off
  nosleep on          disable sleep until manually turned off
  nosleep off         restore normal sleep
  nosleep 30m         disable sleep for 30 minutes (also Ns / Nh)
  nosleep status      show current state and time remaining
  nosleep clean       quit all Dock apps except your whitelist, then no-sleep
  nosleep 1h clean    same, and restore normal sleep after 1 hour
  nosleep insist      turn on even below 15% battery (disables the cutoff)
  nosleep sound       manage the lid-close chime (sound <Name> | off | on)
  nosleep whitelist   manage which apps survive a clean (pulls from running apps)

On a laptop, closing the lid while on plays a chime (see 'nosleep sound').
Sleep is restored automatically if the battery drops below 15% (unless you insist).
Durations over 1 hour ask for confirmation first.
EOF
}

# owl <color> <primary> [secondary] [face]
owl() {
  local C="$1" primary="$2" secondary="${3:-}" face="${4:-o,o}"
  printf '\n'
  printf '   %s ,_,  %s\n'  "$C" "$RST"
  printf '   %s{%s}%s   %s%s%s%s\n' "$C" "$face" "$RST" "$BLD" "$C" "$primary" "$RST"
  printf '   %s/)__)%s   %s%s%s\n' "$C" "$RST" "$C" "$secondary" "$RST"
  printf '   %s-"-"-%s\n' "$C" "$RST"
  printf '\n'
}

fmt_duration() {
  local s=$1
  if   (( s >= 3600 )); then printf '%dh %dm' $(( s / 3600 )) $(( (s % 3600) / 60 ))
  elif (( s >= 60 ));   then printf '%dm %ds' $(( s / 60 )) $(( s % 60 ))
  else                       printf '%ds' "$s"
  fi
}

# Capture-then-match (no pipe): `grep -q` would close the pipe early and, under
# `set -o pipefail`, a SIGPIPE from pmset could flip the result. See has_battery.
state() {
  local o; o=$(pmset -g 2>/dev/null) || true
  if [[ "$o" =~ SleepDisabled[[:space:]]+1 ]]; then echo 1; else echo 0; fi
}

cancel_timer() {
  if [ -f "$PIDFILE" ]; then
    sudo kill "$(awk '{print $1}' "$PIDFILE")" 2>/dev/null || true
    sudo rm -f "$PIDFILE"
  fi
}

# True on machines with an internal battery (laptops); false on desktops.
# Capture-then-match, not `| grep -q`: under `set -o pipefail`, grep closing the
# pipe early can SIGPIPE pmset and make the pipeline (wrongly) report failure.
has_battery() {
  case "$(pmset -g batt 2>/dev/null)" in
    *InternalBattery*) return 0 ;;
    *) return 1 ;;
  esac
}

# Current battery charge as an integer percent, or empty if there's no battery.
# Bash-regex on captured output (no pipe) for the same pipefail-safety reason.
battery_pct() {
  local o; o=$(pmset -g batt 2>/dev/null) || true
  [[ "$o" =~ ([0-9]+)% ]] && printf '%s' "${BASH_REMATCH[1]}"
}

# Dim hints shown under the "No Sleep ON" banner (laptops only): the low-battery
# cutoff (or an insist warning) and, when the lid-close chime is on, a reminder
# that it's active.
activation_note() {
  has_battery || return 0
  if [ "${INSIST:-0}" = 1 ]; then
    printf '   %s⚠️  Battery safety OFF for this session (insisted).%s\n' \
      "$YEL" "$RST"
  else
    printf '   %sWill restore sleep if battery drops below %d%%.%s\n' \
      "$DIM" "$BATTERY_MIN" "$RST"
  fi
  [ "$(load_sound)" != off ] && \
    printf '   %sLid close sound reminder ON%s\n' "$DIM" "$RST"
  printf '\n'
}

# Rebuild the command the user ran, with 'insist' added, for the refusal hint.
insist_suggestion() {
  local s="nosleep"
  [ -n "${DUR_TOKEN:-}" ] && s="$s $DUR_TOKEN"
  s="$s insist"
  [ "${CLEAN:-0}" = 1 ] && s="$s clean"
  printf '%s' "$s"
}

# Refuse to enable when the battery is below the cutoff, unless the user
# insisted. Runs before any enable path touches pmset (and before clean quits
# apps). Exits the process on refusal.
battery_guard() {
  [ "${INSIST:-0}" = 1 ] && return 0
  has_battery || return 0
  local b; b=$(battery_pct) || return 0
  [ -n "$b" ] || return 0
  if [ "$b" -lt "$BATTERY_MIN" ]; then
    printf '%sBattery <%d%%. nosleep not enabled.%s\n' "$YEL" "$BATTERY_MIN" "$RST"
    printf "'%s' to turn on anyway.\n" "$(insist_suggestion)"
    exit 1
  fi
}

# ----- lid-close chime -----

# True when the clamshell (lid) is physically closed. Reflects the hardware
# sensor, so it works even while disablesleep keeps the Mac awake. Capture-then-
# match, not `| grep -q`: ioreg's output is larger than the pipe buffer, so a
# grep that matched and exited early would SIGPIPE ioreg and, under pipefail,
# misreport the lid as open (the same hazard fixed in has_battery/state).
lid_closed() {
  local o; o=$(ioreg -r -k AppleClamshellState -d 4 2>/dev/null) || true
  [[ "$o" == *'"AppleClamshellState" = Yes'* ]]
}

# Names of the stock system sounds, one per line.
list_sounds() {
  local f
  for f in /System/Library/Sounds/*.aiff; do
    [ -e "$f" ] || continue
    basename "$f" .aiff
  done
}

# Effective chime setting: a sound name, or "off". A missing/blank config, or a
# stored name whose file has vanished, falls back to DEFAULT_SOUND.
load_sound() {
  local v
  if [ -f "$SOUND_FILE" ]; then
    v=$(head -1 "$SOUND_FILE" 2>/dev/null || true)
    case "$v" in
      off) echo off; return ;;
      "")  echo "$DEFAULT_SOUND"; return ;;
      *)
        if [ -f "/System/Library/Sounds/$v.aiff" ]; then echo "$v"
        else echo "$DEFAULT_SOUND"; fi
        return ;;
    esac
  fi
  echo "$DEFAULT_SOUND"
}

# Play a chime into the logged-in user's audio session. Called from the root
# watcher, which can't reach that session directly, so it hops to the console
# user via launchctl. Best-effort and backgrounded: never blocks or breaks the
# watcher's real job.
play_sound() {
  local f="/System/Library/Sounds/$1.aiff"
  [ -f "$f" ] || return 0
  local user uid
  user=$(stat -f%Su /dev/console 2>/dev/null || true)
  { [ -z "$user" ] || [ "$user" = root ]; } && return 0
  uid=$(id -u "$user" 2>/dev/null || true)
  [ -n "$uid" ] || return 0
  launchctl asuser "$uid" sudo -u "$user" afplay "$f" >/dev/null 2>&1 &
}

# Interactive 'nosleep sound' subcommand: show/enable/disable/set the chime.
cmd_sound() {
  local arg="${1:-}"
  mkdir -p "$CONFIG_DIR"
  case "$arg" in
    "")
      local cur; cur=$(load_sound)
      printf 'Lid-close chime: %s%s%s\n' "$BLD" "$cur" "$RST"
      printf '%sChange with: nosleep sound <Name> | off | on%s\n' "$DIM" "$RST"
      echo "Available sounds:"
      list_sounds | sed 's/^/  /'
      ;;
    off)
      echo off > "$SOUND_FILE"
      echo "Lid-close chime disabled."
      ;;
    on)
      rm -f "$SOUND_FILE"
      echo "Lid-close chime enabled (default: $DEFAULT_SOUND)."
      ;;
    *)
      local f="/System/Library/Sounds/$arg.aiff"
      if [ ! -f "$f" ]; then
        echo "No system sound named '$arg'. Available:" >&2
        list_sounds | sed 's/^/  /' >&2
        exit 1
      fi
      printf '%s\n' "$arg" > "$SOUND_FILE"
      echo "Lid-close chime set to $arg."
      afplay "$f" >/dev/null 2>&1 || true   # preview
      ;;
  esac
}

# Root background watcher: restore sleep when the deadline passes (0 = never) or
# the battery falls below batt_min (0 = never, when insisted). When a chime is
# set it also watches the lid and plays a sound on each open->closed transition,
# fast-polling (LID_POLL) only while the lid is open. Re-executed as root via
# SELF __watch <deadline> <batt_min> <sound>.
run_watch() {
  local deadline="${1:-0}" batt_min="${2:-$BATTERY_MIN}" snd="${3:-off}"
  local now b nap rem last_batt=0 closed prev_closed=0
  [ "$snd" != off ] && lid_closed && prev_closed=1
  while :; do
    now=$(date +%s)
    if [ "$deadline" != 0 ] && [ "$now" -ge "$deadline" ]; then break; fi
    if [ "$batt_min" != 0 ] && [ $(( now - last_batt )) -ge "$POLL_INTERVAL" ]; then
      b=$(battery_pct) || true
      if [ -n "$b" ] && [ "$b" -lt "$batt_min" ]; then break; fi
      last_batt=$now
    fi
    if [ "$snd" != off ]; then
      if lid_closed; then closed=1; else closed=0; fi
      if [ "$closed" = 1 ] && [ "$prev_closed" = 0 ]; then play_sound "$snd"; fi
      prev_closed=$closed
      if [ "$closed" = 1 ]; then nap=$POLL_INTERVAL; else nap=$LID_POLL; fi
    else
      nap=$POLL_INTERVAL
    fi
    if [ "$deadline" != 0 ]; then
      rem=$(( deadline - now ))
      (( rem < nap )) && nap=$rem
      (( nap < 1 )) && nap=1
    fi
    sleep "$nap"
  done
  pmset -a disablesleep 0
  rm -f "$PIDFILE"
}

# Launch run_watch detached as root, recording "<pid> <deadline>" in PIDFILE.
# Skipped only when nothing needs watching: no deadline, no battery cutoff to
# enforce, and no chime. The chime is a laptop feature (needs a lid), so it's
# gated on has_battery to keep desktops watcher-free.
start_watcher() {
  local deadline="$1"
  local batt_min="${EFFECTIVE_BATT_MIN:-$BATTERY_MIN}"
  local snd; snd=$(load_sound)
  local bat=0; has_battery && bat=1
  [ "$bat" = 1 ] || snd=off
  local need=0
  [ "$deadline" != 0 ] && need=1
  [ "$batt_min" != 0 ] && [ "$bat" = 1 ] && need=1
  [ "$snd" != off ] && need=1
  [ "$need" = 0 ] && return 0
  sudo bash -c "nohup '$SELF' __watch $deadline $batt_min '$snd' >/dev/null 2>&1 & echo \"\$! $deadline\" > '$PIDFILE'"
}

# Guard against unattended lid-closed runs longer than an hour.
confirm_long_duration() {
  local secs=$1
  (( secs > WARN_ABOVE )) || return 0
  [ -t 0 ] || return 0   # non-interactive: can't prompt, so proceed
  printf '%s⚠️  Keep the computer awake for %s while the lid is closed?%s [y/N] ' \
    "$YEL" "$(fmt_duration "$secs")" "$RST"
  local ans; read -r ans
  case "$ans" in
    y|Y|yes|Yes) return 0 ;;
    *) echo "Aborted."; exit 1 ;;
  esac
}

set_on() {
  cancel_timer
  sudo pmset -a disablesleep 1
  start_watcher 0
  owl "$RED" "No Sleep ON" "Until manually turned off."
  activation_note
}

set_off() {
  cancel_timer
  sudo pmset -a disablesleep 0
  owl "$GRN" "Normal Sleep" "" "-,o"
}

set_timed() {
  local secs=$1
  cancel_timer
  sudo pmset -a disablesleep 1
  local deadline
  deadline=$(( $(date +%s) + secs ))
  start_watcher "$deadline"
  owl "$YEL" "No Sleep ON" "Normal in $(fmt_duration "$secs")."
  activation_note
}

show_status() {
  if [ "$(state)" = 1 ]; then
    if [ -f "$PIDFILE" ]; then
      local deadline remaining
      deadline=$(awk '{print $2}' "$PIDFILE")
      remaining=$(( deadline - $(date +%s) ))
      if [ "$remaining" -gt 0 ]; then
        owl "$YEL" "No Sleep ON" "Normal in $(fmt_duration "$remaining")."
        return
      fi
    fi
    owl "$RED" "No Sleep ON" "Until manually turned off."
  else
    owl "$GRN" "Normal Sleep" "" "-,o"
  fi
}

# ---------- clean mode ----------

require_tty() {
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    echo "nosleep $1 is interactive and needs a terminal." >&2
    exit 1
  fi
}

# Dock apps = processes with Dock presence; menu-bar/background apps excluded.
running_dock_apps() {
  osascript <<'EOF'
tell application "System Events" to set appNames to name of every process whose background only is false
set AppleScript's text item delimiters to linefeed
return appNames as text
EOF
}

# The terminal hosting this session must never be quit mid-clean.
host_terminal() {
  case "${TERM_PROGRAM:-}" in
    Apple_Terminal) echo "Terminal" ;;
    iTerm.app)      echo "iTerm2" ;;
    vscode)         echo "Code" ;;
    ghostty)        echo "Ghostty" ;;
    WezTerm)        echo "wezterm-gui" ;;
    WarpTerminal)   echo "Warp" ;;
  esac
}

is_protected() {
  [ "$1" = "Finder" ] && return 0
  [ -n "$HOST_TERM" ] && [ "$1" = "$HOST_TERM" ] && return 0
  return 1
}

load_whitelist() {
  WL=()
  if [ -f "$WHITELIST_FILE" ]; then
    local line
    while IFS= read -r line; do
      case "$line" in ''|'#'*) continue ;; esac
      WL+=("$line")
    done < "$WHITELIST_FILE"
  fi
}

in_whitelist() {
  local a
  for a in ${WL[@]+"${WL[@]}"}; do
    [ "$a" = "$1" ] && return 0
  done
  return 1
}

get_running_apps() {
  local out
  if ! out=$(running_dock_apps 2>/dev/null) || [ -z "$out" ]; then
    echo "Could not list running apps, this terminal isn't authorized to" >&2
    echo "control System Events. To fix:" >&2
    echo "  1. System Settings > Privacy & Security > Automation >" >&2
    echo "     (this terminal app) > enable System Events" >&2
    echo "  2. Quit and reopen the terminal app, the change doesn't reach" >&2
    echo "     already-running processes." >&2
    echo "  3. Still denied? Reset and let macOS re-prompt:" >&2
    echo "       tccutil reset AppleEvents <terminal-bundle-id>" >&2
    echo "     (e.g. com.apple.Terminal, dev.warp.Warp-Stable)" >&2
    exit 1
  fi
  printf '%s\n' "$out"
}

quit_app() {
  local name=${1//\\/\\\\}
  name=${name//\"/\\\"}
  osascript -e 'ignoring application responses' \
            -e "tell application \"$name\" to quit" \
            -e 'end ignoring' >/dev/null 2>&1 || true
}

# Shared toggle-list renderer. Uses globals ITEMS, MARKS, NOTES.
print_items() {
  local i
  for i in "${!ITEMS[@]}"; do
    if [ "${MARKS[i]}" = x ]; then
      printf '  [%sx%s] %2d. %s%s%s%s\n' "$GRN" "$RST" $(( i + 1 )) "${ITEMS[$i]}" "$DIM" "${NOTES[$i]}" "$RST"
    else
      printf '  [ ] %2d. %s%s%s%s\n' $(( i + 1 )) "${ITEMS[$i]}" "$DIM" "${NOTES[$i]}" "$RST"
    fi
  done
}

toggle_items() {
  local tok="$1" i
  for i in "${!ITEMS[@]}"; do
    if [ "$tok" = "$(( i + 1 ))" ]; then
      if [ "${MARKS[i]}" = x ]; then MARKS[i]=" "; else MARKS[i]=x; fi
      return
    fi
  done
  echo "  (no item $tok)"
}

manage_whitelist() {
  require_tty whitelist
  HOST_TERM="$(host_terminal)"
  load_whitelist
  ITEMS=(); MARKS=(); NOTES=()

  local apps name
  apps=$(get_running_apps) || exit 1
  while IFS= read -r name; do
    is_protected "$name" && continue
    ITEMS+=("$name"); NOTES+=("")
    if in_whitelist "$name"; then MARKS+=(x); else MARKS+=(" "); fi
  done < <(printf '%s\n' "$apps" | sort -f)

  # Whitelisted apps that aren't running, keep them removable.
  local w found i
  for w in ${WL[@]+"${WL[@]}"}; do
    found=0
    for i in "${!ITEMS[@]}"; do
      [ "${ITEMS[$i]}" = "$w" ] && { found=1; break; }
    done
    if [ "$found" = 0 ]; then
      ITEMS+=("$w"); MARKS+=(x); NOTES+=(" (not running)")
    fi
  done

  echo
  echo "${BLD}nosleep whitelist${RST}, checked apps survive 'nosleep clean'."
  echo "${DIM}Note: this list pulls from running apps. To whitelist a new app, launch it first.${RST}"
  local ans tok
  while true; do
    echo
    print_items
    echo
    printf 'Toggle by number (space-separated), (s)ave, (q)uit without saving: '
    read -r ans
    case "$ans" in
      s)
        mkdir -p "$CONFIG_DIR"
        {
          echo "# nosleep whitelist, apps that survive 'nosleep clean'"
          echo "# One app name per line. Managed by 'nosleep whitelist'."
          for i in "${!ITEMS[@]}"; do
            [ "${MARKS[i]}" = x ] && printf '%s\n' "${ITEMS[$i]}"
          done
        } > "$WHITELIST_FILE"
        echo "Saved to $WHITELIST_FILE"
        return
        ;;
      q) echo "Not saved."; return ;;
      *)
        for tok in $ans; do toggle_items "$tok"; done
        ;;
    esac
  done
}

do_clean() {
  local dur="${1:-}"
  if [ ! -f "$WHITELIST_FILE" ]; then
    echo "No whitelist configured yet, run 'nosleep whitelist' first" >&2
    echo "to choose which apps survive a clean." >&2
    exit 1
  fi
  require_tty clean
  HOST_TERM="$(host_terminal)"
  load_whitelist
  ITEMS=(); MARKS=(); NOTES=()
  local kept="" apps name

  apps=$(get_running_apps) || exit 1
  while IFS= read -r name; do
    if is_protected "$name"; then
      kept="$kept  🔒 $name"
    elif in_whitelist "$name"; then
      kept="$kept  ✓ $name"
    else
      ITEMS+=("$name"); MARKS+=(x); NOTES+=("")
    fi
  done < <(printf '%s\n' "$apps" | sort -f)

  if [ "${#ITEMS[@]}" = 0 ]; then
    echo "Nothing to quit, everything running is whitelisted or protected."
  else
    echo
    echo "${BLD}⚠️  nosleep clean${RST}, about to quit the checked apps (same as Cmd-Q;"
    echo "unsaved-work dialogs may appear)."
    [ -n "$kept" ] && echo "${DIM}Kept:$kept${RST}"
    local ans tok i
    while true; do
      echo
      print_items
      echo
      printf 'Toggle by number, (a)ll, (n)one, (y) quit checked + no-sleep, (q) abort: '
      read -r ans
      case "$ans" in
        y) break ;;
        q|'') echo "Aborted, nothing quit, sleep settings untouched."; return ;;
        a) for i in "${!ITEMS[@]}"; do MARKS[i]=x; done ;;
        n) for i in "${!ITEMS[@]}"; do MARKS[i]=" "; done ;;
        *) for tok in $ans; do toggle_items "$tok"; done ;;
      esac
    done

    local count=0
    for i in "${!ITEMS[@]}"; do
      if [ "${MARKS[i]}" = x ]; then
        printf 'Quitting %s…\n' "${ITEMS[$i]}"
        quit_app "${ITEMS[$i]}"
        count=$(( count + 1 ))
      fi
    done
    echo "Quit $count app(s)."
  fi

  if [ -n "$dur" ]; then set_timed "$dur"; else set_on; fi
}

# ---------- dispatch ----------

# Internal: root background watcher, re-executed by start_watcher.
if [ "${1:-}" = "__watch" ]; then
  run_watch "${2:-0}" "${3:-$BATTERY_MIN}" "${4:-off}"
  exit 0
fi

# 'nosleep sound' manages the lid-close chime.
if [ "${1:-}" = sound ]; then
  shift
  cmd_sound "${1:-}"
  exit 0
fi

DUR=""
DUR_TOKEN=""
CLEAN=0
INSIST=0
CMD=""
for arg in "$@"; do
  case "$arg" in
    clean) CLEAN=1 ;;
    insist) INSIST=1 ;;
    on|off|status|toggle|whitelist)
      [ -n "$CMD" ] && { usage >&2; exit 1; }
      CMD="$arg"
      ;;
    help|--help|-h) usage; exit 0 ;;
    version|--version|-v) echo "nosleep $VERSION"; exit 0 ;;
    *)
      if [[ "$arg" =~ ^([0-9]+)([smh])$ ]]; then
        n=${BASH_REMATCH[1]}
        DUR_TOKEN="$arg"
        case "${BASH_REMATCH[2]}" in
          s) DUR=$n ;;
          m) DUR=$(( n * 60 )) ;;
          h) DUR=$(( n * 3600 )) ;;
        esac
      else
        usage >&2
        exit 1
      fi
      ;;
  esac
done

# insist only makes sense when enabling.
if [ "$INSIST" = 1 ]; then
  case "${CMD:-}" in
    ""|on|toggle) ;;
    *) echo "insist can't be combined with '$CMD'." >&2; exit 1 ;;
  esac
fi

# Insisting disables the watcher's battery cutoff for this session.
EFFECTIVE_BATT_MIN=$BATTERY_MIN
[ "$INSIST" = 1 ] && EFFECTIVE_BATT_MIN=0

# Will this invocation enable no-sleep? Guard the battery before we prompt for a
# long run or (in clean) quit anything.
WILL_ENABLE=0
if [ "$CLEAN" = 1 ] || [ -n "$DUR" ]; then
  WILL_ENABLE=1
else
  case "${CMD:-toggle}" in
    on) WILL_ENABLE=1 ;;
    toggle) [ "$(state)" = 1 ] || WILL_ENABLE=1 ;;
  esac
fi
[ "$WILL_ENABLE" = 1 ] && battery_guard

# Confirm long lid-closed runs before quitting apps or flipping any setting.
[ -n "$DUR" ] && confirm_long_duration "$DUR"

if [ "$CLEAN" = 1 ]; then
  if [ -n "$CMD" ]; then
    echo "clean can't be combined with '$CMD'." >&2
    exit 1
  fi
  do_clean "$DUR"
elif [ -n "$DUR" ]; then
  [ -n "$CMD" ] && { usage >&2; exit 1; }
  set_timed "$DUR"
else
  case "${CMD:-toggle}" in
    on)  set_on ;;
    off) set_off ;;
    status) show_status ;;
    whitelist) manage_whitelist ;;
    toggle)
      if [ "$(state)" = 1 ]; then set_off; else set_on; fi
      ;;
  esac
fi
